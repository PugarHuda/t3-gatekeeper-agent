/// gate-contract WIT world — hardware-enforced action mandate gate.
///
/// A delegated agent proves a user's eligibility off-contract (a BBS+
/// verifiable credential, verified in the agent layer). This contract is the
/// SECOND, independent gate: it enforces the user's spending MANDATE inside the
/// TEE — max amount, allowed asset list, allowed action kinds, and an expiry —
/// so the bound is held by hardware, not by the agent's own promise.
///
/// Imports:
///   - tenant-context: tenant DID + cluster-pinned timestamp (for expiry).
///   - logging:        audit/debug lines flushed to the per-contract ring.
///   - kv-store:       reads the `mandate` map (z:<tid>:mandate) so the bound
///                     is provisioned once by the tenant admin and cannot be
///                     overridden by the calling agent at invoke time.
package z:gate-contract@0.1.0;

world gate-contract {
    import host:tenant/tenant-context@1.0.0;
    import host:interfaces/logging@2.1.0;
    import host:interfaces/kv-store@2.1.0;

    export contracts;
}

interface contracts {
    /// Standard 3-field envelope used by all tenant contracts.
    record generic-input {
        input:        option<list<u8>>,
        user-profile: option<list<u8>>,
        context:      option<list<u8>>,
    }

    /// Evaluate a proposed action against the user's hardware-held mandate.
    ///
    /// Input  (JSON): { action: { kind, asset, amount_cents },
    ///                  mandate?: { max_amount_cents, allowed_assets[],
    ///                              allowed_kinds[], expires_at_secs } }
    ///   allowed_* are deny-by-default: an empty list permits nothing; the
    ///   wildcard "*" permits any value. expires_at_secs 0 means no expiry.
    ///   `mandate` is OPTIONAL: when omitted the contract reads the
    ///   tenant-provisioned mandate from the `mandate` KV map (key `default`),
    ///   which the agent CANNOT tamper with. When present (demo / dry-run) the
    ///   inline mandate is used and the response flags `mandate_source`.
    ///
    /// Output (JSON): { decision: "approved"|"rejected", reasons[],
    ///                  tenant_did, evaluated_at_secs, mandate_source,
    ///                  audit: { kind, asset, amount_cents, max_amount_cents } }
    evaluate: func(req: generic-input) -> result<list<u8>, string>;

    /// Stateful cumulative-spend gate. Tracks the running total per `window` in
    /// the `spent` KV map and approves only while `total + amount` stays within
    /// `daily_limit_cents`. Demonstrates hardware-enforced velocity limits that
    /// hold ACROSS invocations (the agent cannot reset the counter).
    /// Input  (JSON): { action:{kind,asset,amount_cents}, daily_limit_cents, window }
    /// Output (JSON): { decision, spent_before, spent_after, daily_limit_cents,
    ///                  remaining, window }
    spend: func(req: generic-input) -> result<list<u8>, string>;
}
