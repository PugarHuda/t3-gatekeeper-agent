# Copy to .env and fill from the T3N token-claim success page.
# NOTE: the API key is shown only once and grants full sandbox access — keep it secret.
T3N_API_KEY=0x...
DID=did:t3n:...

# Optional — credential-revocation pre-gate (agent/src/revocation.mjs).
# Leave unset to skip the check (fail-open). Set BOTH to enforce: the agent calls
# @terminal3/revoke_vc isRevoked() against this EVM registry before acting.
# REVOCATION_REGISTRY_ADDRESS=0x...
# REVOCATION_RPC_URL=https://...

# Optional — ERC-8004 on-chain identity (npm run register:erc8004).
# Set all three to mint the agent NFT; the script refuses to run otherwise.
# ERC8004_RPC_URL=https://...
# ERC8004_REGISTRY_ADDRESS=0x...
# ERC8004_PRIVATE_KEY=0x...            # a GAS-FUNDED key (owns the agent NFT)
# AGENT_URI=https://...               # defaults to the hosted agent-card.json
